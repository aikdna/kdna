        "value": "sha256:936afdde43ff207fa7570cf1524f36d89ad2b6b95f0a5811ba0d985878121d6e",
        "basis": "kdna-container-bytes-v1",
        "source": "kdna.json.content_digest"
      },
      "expected_phase": "schema",
      "expected_code": "SCHEMA_INVALID"
    },
    {
