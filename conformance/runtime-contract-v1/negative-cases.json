      "expected_phase": "schema",
      "expected_code": "KDNA_ASSET_FILE_REQUIRED"
    },
    {
      "name": "plan-generic-digest-is-forbidden",
      "base": "plan",
      "operation": "add",
      "path": "/asset_ref/digest",
