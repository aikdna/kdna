      "operation": "remove",
      "path": "/asset_ref/asset_uid",
      "expected_phase": "schema",
      "expected_code": "SCHEMA_INVALID"
    },
    {
      "name": "plan-present-null-nonnullable-version",
      "base": "plan",
      "operation": "replace",
      "path": "/asset_ref/version",
      "value": null,
      "expected_phase": "schema",
      "expected_code": "SCHEMA_INVALID"
    },
    {
      "name": "plan-source-directory-runtime-not-permitted",
      "base": "plan",
      "operation": "replace",
      "path": "/projection_request/require_packaged_asset",
      "value": false,
      "expected_phase": "schema",
      "expected_code": "KDNA_ASSET_FILE_REQUIRED"
    },
    {
      "name": "plan-capsule-1-acceptance-is-forbidden",
      "base": "plan",
      "operation": "replace",
      "path": "/projection_request/accepted_capsule_versions",
