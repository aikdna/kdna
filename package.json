{
  "name": "@aikdna/kdna-monorepo",
  "version": "0.7.0",
  "private": true,
  "description": "KDNA protocol specification, core library, and domain registry.",
  "type": "commonjs",
  "scripts": {
    "lint": "eslint packages/kdna-core/src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:examples": "echo 'Use npx kdna dev validate on individual domain repos'",
    "validate:examples": "echo 'Use npx kdna dev validate on individual domain repos'",
    "validate:runtime-contract": "node scripts/validate-runtime-contract.js",
    "audit:public-confidence": "node scripts/audit-public-confidence.js",
    "validate:app-schemas": "node scripts/validate-app-schemas.js",
    "validate:protocol-fixtures": "node scripts/validate-protocol-fixtures.js",
    "validate:rfc0013-schemas": "node scripts/validate-rfc0013-schemas.js",
    "test": "npm --workspace @aikdna/kdna-core test && npm --workspace @aikdna/kdna-eval test",
    "conformance": "node conformance/run.mjs",
    "conformance:phase2": "node conformance/run.mjs --profile phase2-protocol",
    "certify:asset-loader": "node conformance/run.mjs --profile asset-loader",
    "test:registry-trust": "node tests/registry-trust/run.mjs",
    "smoke:installed-domains": "bash scripts/smoke-installed-domains.sh",
    "check:pack": "node scripts/check-pack-contents.js",
    "release:preflight": "node scripts/release-preflight.js",
    "test:core-smoke": "node scripts/core-smoke.js",
    "test:ecosystem-lock": "node scripts/ecosystem-version-lock.js --strict",
    "v1:validate": "node scripts/v1-validate.mjs",
    "v1:inspect": "node scripts/v1-inspect.mjs",
    "v1:pack": "node scripts/v1-pack.mjs",
    "v1:unpack": "node scripts/v1-unpack.mjs",
    "pretest": "node scripts/core-smoke.js"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aikdna/kdna.git"
  },
  "homepage": "https://aikdna.com",
  "bugs": {
    "url": "https://github.com/aikdna/kdna/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@aikdna/kdna-cli": "^0.19.0",
    "@eslint/js": "^9.39.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.39.0",
    "prettier": "^3.8.3"
  }
}
