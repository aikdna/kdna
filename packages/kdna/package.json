{
  "name": "@aikdna/kdna",
  "version": "0.13.1",
  "description": "KDNA toolkit compatibility package. The kdna CLI binary has moved to @aikdna/kdna-cli \u2014 use npm install -g @aikdna/kdna-cli.",
  "type": "commonjs",
  "bin": {
    "kdna-lint": "bin/kdna-lint.js",
    "kdna-validate": "bin/kdna-validate.js"
  },
  "files": [
    "bin/",
    "src/",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/*.test.js && node bin/kdna.js --help >/dev/null && node bin/kdna-lint.js --help >/dev/null && node bin/kdna-validate.js --help >/dev/null",
    "prepublishOnly": "npm run release:check",
    "release:check": "node ../../scripts/check-post-cutover-naming.mjs && node scripts/check-release-readiness.js",
    "release:pack": "node scripts/prepare-release-artifact.js",
    "release:smoke": "node scripts/smoke-release-artifact.js",
    "publish:guard": "node scripts/check-publish-duplicate.js",
    "publish:verified": "node scripts/publish-verified-artifact.js"
  },
  "keywords": [
    "kdna",
    "kdna-cli",
    "ai-agent",
    "domain-judgment",
    "judgment-asset",
    "kdna-core"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aikdna/kdna.git",
    "directory": "packages/kdna"
  },
  "homepage": "https://aikdna.com",
  "bugs": {
    "url": "https://github.com/aikdna/kdna/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@aikdna/kdna-cli": "0.35.0",
    "@aikdna/kdna-core": "0.20.0"
  }
}
