{
  "name": "@aikdna/kdna-eval",
  "version": "0.3.2",
  "description": "KDNA consumption evaluation framework — configurable scoring, multi-gate gating, replay regression, and cost tracking.",
  "type": "commonjs",
  "main": "src/index.js",
  "module": "src/index.mjs",
  "exports": {
    ".": {
      "import": "./src/index.mjs",
      "require": "./src/index.js",
      "types": "./src/types.d.ts"
    },
    "./loader": {
      "import": "./src/loader.mjs",
      "require": "./src/loader.js",
      "types": "./src/loader.d.ts"
    },
    "./route": {
      "import": "./src/route.mjs",
      "require": "./src/route.js",
      "types": "./src/route.d.ts"
    },
    "./replay": {
      "import": "./src/replay.mjs",
      "require": "./src/replay.js",
      "types": "./src/replay.d.ts"
    },
    "./gates": {
      "import": "./src/gates.mjs",
      "require": "./src/gates.js",
      "types": "./src/gates.d.ts"
    },
    "./cost": {
      "import": "./src/cost.mjs",
      "require": "./src/cost.js",
      "types": "./src/cost.d.ts"
    },
    "./consume": {
      "import": "./src/consume.mjs",
      "require": "./src/consume.js",
      "types": "./src/consume.d.ts"
    },
    "./route-card": {
      "import": "./src/route-card.mjs",
      "require": "./src/route-card.js",
      "types": "./src/route-card.d.ts"
    },
    "./consumer-index": {
      "import": "./src/consumer-index.mjs",
      "require": "./src/consumer-index.js",
      "types": "./src/consumer-index.d.ts"
    },
    "./assay": {
      "import": "./src/assay.mjs",
      "require": "./src/assay.js",
      "types": "./src/assay.d.ts"
    },
    "./cluster-assay": {
      "import": "./src/cluster-assay.mjs",
      "require": "./src/cluster-assay.js",
      "types": "./src/cluster-assay.d.ts"
    },
    "./package.json": "./package.json"
  },
  "types": "src/types.d.ts",
  "scripts": {
    "test": "node test/test-wrapper.js",
    "typecheck": "tsc --noEmit --strict --skipLibCheck false --lib es2022 src/types.d.ts",
    "release:check": "node ../../scripts/check-post-cutover-naming.mjs && node ../../scripts/check-scoped-release-readiness.mjs --package=packages/kdna-eval --scope=eval --label=eval",
    "release:evidence:check": "node ../../scripts/check-scoped-release-readiness.mjs --package=packages/kdna-eval --scope=eval --label=eval --evidence=release-evidence/artifact-manifest.json",
    "prepublishOnly": "npm run release:check && npm run release:evidence:check && npm test && npm run typecheck"
  },
  "files": [
    "src/",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "kdna",
    "scoring",
    "evaluation",
    "dimension",
    "judgment"
  ],
  "devDependencies": {
    "typescript": "^7.0.2"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aikdna/kdna.git",
    "directory": "packages/kdna-eval"
  },
  "homepage": "https://aikdna.com"
}
