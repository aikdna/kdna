{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aikdna/kdna/specs/agent-host-2-request.schema.json",
  "title": "KDNA Agent Host 2 Request",
  "description": "Strict Host 2 request carrying one exact Runtime Capsule 2, its Plan correlation, detached delivery digest P, projection/result contracts, and enforceable limits.",
  "type": "object",
  "required": [
    "protocol",
    "request_id",
    "plan_ref",
    "runtime_contract",
    "projection_contract",
    "result_contract",
    "budget",
    "constraints",
    "phase",
    "task",
    "authority",
    "asset",
    "capsule"
  ],
  "additionalProperties": false,
  "properties": {
    "protocol": { "const": "kdna.agent-host/2" },
    "request_id": { "type": "string", "pattern": "^host_[0-9a-f]{24}$" },
    "plan_ref": { "$ref": "#/$defs/planRef" },
    "runtime_contract": { "$ref": "#/$defs/runtimeContract" },
    "projection_contract": { "$ref": "#/$defs/projectionContract" },
    "result_contract": { "$ref": "#/$defs/resultContract" },
    "budget": { "$ref": "#/$defs/budget" },
    "constraints": { "$ref": "#/$defs/constraints" },
    "phase": { "const": "single_judgment" },
    "task": { "$ref": "#/$defs/task" },
    "authority": { "$ref": "#/$defs/authority" },
    "asset": { "$ref": "#/$defs/asset" },
    "capsule": {
      "$ref": "https://github.com/aikdna/kdna/specs/runtime-capsule-2.schema.json"
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "assetId": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*(:[a-zA-Z0-9_.-]+)+$"
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([+-].+)?$"
    },
    "planRef": {
      "type": "object",
      "required": ["plan_id", "plan_digest_profile", "plan_digest"],
      "additionalProperties": false,
      "properties": {
        "plan_id": { "type": "string", "pattern": "^plan_[0-9a-f]{16}$" },
        "plan_digest_profile": { "const": "kdna-consumption-plan-jcs-v1" },
        "plan_digest": { "$ref": "#/$defs/sha256" }
      }
    },
    "runtimeContract": {
      "type": "object",
      "required": ["capsule_version", "capsule_digest_profile", "capsule_delivery_digest"],
      "additionalProperties": false,
      "properties": {
        "capsule_version": { "const": "2.0" },
        "capsule_digest_profile": { "const": "kdna-capsule-jcs-v1" },
        "capsule_delivery_digest": { "$ref": "#/$defs/sha256" }
      }
    },
    "projectionContract": {
      "type": "object",
      "required": ["profile", "required_digest_profile", "require_packaged_asset"],
      "additionalProperties": false,
      "properties": {
        "profile": { "enum": ["index", "compact", "scenario", "full"] },
        "required_digest_profile": { "const": "kdna-capsule-digests-v1" },
        "require_packaged_asset": { "const": true }
      }
    },
    "resultContract": {
      "type": "object",
      "required": ["shape"],
      "additionalProperties": false,
      "properties": {
        "shape": { "const": "structured_judgment" }
      }
    },
    "budget": {
      "$ref": "https://github.com/aikdna/kdna/specs/consumption-plan-1.schema.json#/$defs/budget"
    },
    "constraints": {
      "$ref": "https://github.com/aikdna/kdna/specs/consumption-plan-1.schema.json#/$defs/constraints"
    },
    "task": {
      "$ref": "https://github.com/aikdna/kdna/specs/consumption-plan-1.schema.json#/$defs/task"
    },
    "authority": {
      "type": "object",
      "required": ["asset_id", "role", "final_decision"],
      "additionalProperties": false,
      "properties": {
        "asset_id": { "$ref": "#/$defs/assetId" },
        "role": { "const": "primary" },
        "final_decision": { "const": true }
      }
    },
    "asset": {
      "type": "object",
      "required": [
        "asset_id",
        "asset_uid",
        "version",
        "judgment_version",
        "access",
        "role",
        "expected_digests"
      ],
      "additionalProperties": false,
      "properties": {
        "asset_id": { "$ref": "#/$defs/assetId" },
        "asset_uid": { "type": "string", "format": "uri" },
        "version": { "$ref": "#/$defs/semver" },
        "judgment_version": { "$ref": "#/$defs/semver" },
        "access": { "enum": ["public", "licensed", "remote"] },
        "role": { "const": "primary" },
        "expected_digests": {
          "$ref": "https://github.com/aikdna/kdna/specs/consumption-plan-1.schema.json#/$defs/expectedDigests"
        }
      }
    }
  }
}
