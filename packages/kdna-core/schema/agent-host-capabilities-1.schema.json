{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aikdna/kdna/specs/agent-host-capabilities-1.schema.json",
  "title": "KDNA Agent Host Capability Descriptor 1.0",
  "description": "Orthogonal capabilities observed before Plan 1.0 execution. Supported execution pairs are decided by the execution contract verifier, not inferred as a cartesian product by this schema.",
  "type": "object",
  "required": [
    "type",
    "version",
    "capability_basis",
    "host_protocols",
    "capsule_versions",
    "capsule_digest_profiles"
  ],
  "additionalProperties": false,
  "properties": {
    "type": { "const": "kdna.agent-host.capabilities" },
    "version": { "const": "1.0" },
    "capability_basis": {
      "enum": ["registered_descriptor", "legacy_assumption"]
    },
    "host_protocols": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["kdna.agent-host/2", "kdna.agent-host/1"] }
    },
    "capsule_versions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["2.0", "1.0"] }
    },
    "capsule_digest_profiles": {
      "type": "array",
      "uniqueItems": true,
      "items": { "const": "kdna-capsule-jcs-v1" }
    }
  }
}
