{
  "name": "@aikdna/kdna-core",
  "version": "0.12.0",
  "description": "KDNA core library — load, validate, lint, and render KDNA domain judgment assets. Supports KDNA Container format (payload.kdnab via CBOR).",
  "type": "commonjs",
  "main": "src/index.js",
  "module": "src/index.mjs",
  "exports": {
    ".": {
      "import": "./src/index.mjs",
      "require": "./src/index.js",
      "types": "./src/types.d.ts"
    },
    "./package.json": "./package.json",
    "./schema/*": "./schema/*",
    "./v1": {
      "import": "./src/v1/index.mjs",
      "require": "./src/v1/index.js",
      "types": "./src/types.d.ts"
    }
  },
  "types": "src/types.d.ts",
  "scripts": {
    "test": "node --test test/*.test.js && node -e \"const m = require('./src/index.js'); console.log('kdna-core exports:', Object.keys(m).join(', '));\"",
    "prepublishOnly": "npm --prefix ../.. run ecosystem-gate"
  },
  "files": [
    "src/",
    "schema/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "keywords": [
    "kdna",
    "kdna-core",
    "ai-agent",
    "domain-cognition"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aikdna/kdna.git",
    "directory": "packages/kdna-core"
  },
  "homepage": "https://aikdna.com",
  "peerDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "peerDependenciesMeta": {
    "ajv": {
      "optional": true
    },
    "ajv-formats": {
      "optional": true
    }
  },
  "dependencies": {
    "@noble/hashes": "^1.8.0",
    "cbor-x": "^1.6.4"
  }
}
