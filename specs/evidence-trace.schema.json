{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aikdna.com/schemas/evidence-trace.schema.json",
  "title": "KDNA Evidence Trace",
  "description": "Unified product-grade trace extending the runtime judgment trace with artifact references, quality report linkage, human review status, and complete judgment detail. Every KDNA-governed generation — whether a single agent call or a multi-stage pipeline — produces an Evidence Trace that links together: Route Result → Judgment Trace → Artifact References → Quality Report → Human Review.",
  "type": "object",
  "required": ["trace_version", "trace_id", "timestamp", "agent_info", "loaded_kdna"],
  "properties": {
    "trace_version": {
      "type": "string",
      "enum": ["1.0.0"],
      "description": "Evidence Trace schema version."
    },
    "trace_id": {
      "type": "string",
      "description": "Unique identifier for this trace. UUID v4 recommended."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this trace record was created."
    },
    "session_id": {
      "type": "string",
      "description": "Groups traces across a multi-stage pipeline run. Shared by all traces in the same Run (per RFC-0012)."
    },
    "trace_type": {
      "type": "string",
      "enum": ["route", "load", "generation", "postvalidate", "fidelity", "human_review"],
      "description": "Which phase of the artifact generation pipeline produced this trace."
    },
    "parent_trace_id": {
      "type": "string",
      "description": "For traces produced within a pipeline: the trace_id of the preceding stage's trace. Enables trace-chain traversal."
    },
    "agent_info": {
      "type": "object",
      "description": "Which agent and model produced this trace.",
      "required": ["agent_name"],
      "properties": {
        "agent_name": {
          "type": "string",
          "description": "Claude Code, Codex, OpenCode, Cursor, cli, course-engine, daily-letter-engine, etc."
        },
        "agent_version": { "type": "string" },
        "model": { "type": "string", "description": "LLM model used for generation." },
        "model_config": {
          "type": "object",
          "description": "Generation parameters.",
          "properties": {
            "temperature": { "type": "number" },
            "top_p": { "type": "number" },
            "max_tokens": { "type": "integer" }
          }
        }
      }
    },
    "loaded_kdna": {
      "type": "array",
      "description": "KDNA domains loaded for this trace.",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "version"],
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "string" },
          "judgment_version": { "type": "string" },
          "digest": { "type": "string", "description": "Asset digest (sha256:hex)." },
          "role": {
            "type": "string",
            "enum": [
              "primary",
              "advisor",
              "constraint",
              "risk_guard",
              "evaluator",
              "style_and_trust"
            ]
          },
          "load_profile": { "type": "string", "enum": ["index", "compact", "scenario", "full"] },
          "source": { "type": "string", "enum": ["local", "registry", "private-registry"] }
        }
      }
    },
    "route_result": {
      "type": "object",
      "description": "The route decision that selected these KDNA domains. Populated for trace_type=route traces.",
      "properties": {
        "status": { "type": "string" },
        "action": { "type": "string" },
        "confidence": { "type": "number" },
        "reason": { "type": "string" },
        "trust_passed": { "type": "boolean" },
        "trust_failures": { "type": "array", "items": { "type": "string" } }
      }
    },
    "input_hash": {
      "type": "string",
      "description": "SHA-256 hash of the normalized input text. Enables trace deduplication and privacy-preserving trace linking."
    },
    "input_summary": {
      "type": "string",
      "description": "One-line summary of the task or user input, for human readability in trace logs."
    },
    "output_hash": {
      "type": "string",
      "description": "SHA-256 hash of the agent's generated output. Links trace to the specific output version."
    },
    "triggered_axioms": {
      "type": "array",
      "description": "Domain axioms that were triggered during generation.",
      "items": {
        "type": "object",
        "required": ["id", "domain"],
        "properties": {
          "id": { "type": "string", "description": "Axiom ID from KDNA_Core.json." },
          "domain": { "type": "string" },
          "statement": { "type": "string", "description": "One-sentence axiom statement." },
          "transfer_level": {
            "type": "string",
            "enum": ["operationalized", "referenced", "mentioned"],
            "description": "How deeply the axiom entered the agent's reasoning."
          },
          "evidence": {
            "type": "string",
            "description": "Quote or summary showing where the axiom appeared in the output."
          }
        }
      }
    },
    "triggered_frameworks": {
      "type": "array",
      "description": "Domain frameworks applied during generation.",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "domain": { "type": "string" },
          "name": { "type": "string" },
          "steps_applied": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "triggered_misunderstandings": {
      "type": "array",
      "description": "Domain misunderstandings that were detected and avoided.",
      "items": {
        "type": "object",
        "required": ["id", "domain"],
        "properties": {
          "id": { "type": "string" },
          "domain": { "type": "string" },
          "wrong_belief": { "type": "string" },
          "correction_applied": { "type": "string" }
        }
      }
    },
    "self_checks": {
      "type": "array",
      "description": "Self-check results with per-check detail.",
      "items": {
        "type": "object",
        "required": ["check_id", "domain", "passed"],
        "properties": {
          "check_id": { "type": "string" },
          "domain": { "type": "string" },
          "question": { "type": "string" },
          "passed": { "type": "boolean" },
          "reason": { "type": "string" }
        }
      }
    },
    "banned_terms_avoided": {
      "type": "array",
      "description": "Banned terms that were successfully avoided.",
      "items": {
        "type": "object",
        "required": ["term", "domain"],
        "properties": {
          "term": { "type": "string" },
          "domain": { "type": "string" },
          "replaced_with": { "type": "string" }
        }
      }
    },
    "violations": {
      "type": "array",
      "description": "Boundary violations or banned term usage detected.",
      "items": {
        "type": "object",
        "required": ["type", "severity", "description"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["banned_term_used", "boundary_crossed", "risk_triggered", "self_check_failed"]
          },
          "severity": { "type": "string", "enum": ["error", "warning", "info"] },
          "description": { "type": "string" },
          "domain": { "type": "string" }
        }
      }
    },
    "generated_judgment": {
      "type": "object",
      "description": "The final judgment produced by the agent.",
      "properties": {
        "classification": {
          "type": "string",
          "description": "Situation type the agent classified the input as."
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "recommended_action": { "type": "string" },
        "reasoning_summary": { "type": "string" },
        "missing_elements": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Information the agent identified as missing."
        }
      }
    },
    "artifact_refs": {
      "type": "array",
      "description": "Artifacts produced during this trace's generation. Links to RFC-0012 ArtifactEnvelope.",
      "items": {
        "type": "object",
        "required": ["artifact_id", "artifact_type"],
        "properties": {
          "artifact_id": { "type": "string" },
          "artifact_type": { "type": "string" },
          "content_digest": { "type": "string" },
          "relationship": {
            "type": "string",
            "enum": ["produced", "consumed", "evaluated", "finalized"],
            "description": "How this artifact relates to this trace."
          }
        }
      }
    },
    "quality_report_refs": {
      "type": "array",
      "description": "Quality reports linked to this trace.",
      "items": {
        "type": "object",
        "required": ["report_id"],
        "properties": {
          "report_id": { "type": "string" },
          "report_type": {
            "type": "string",
            "enum": ["llm_critique", "fidelity", "deterministic", "human_review"]
          },
          "overall_result": { "type": "string", "enum": ["pass", "fail", "conditional_pass"] },
          "score": { "type": "number" }
        }
      }
    },
    "human_review_ref": {
      "type": "object",
      "description": "Human review linked to this trace's artifacts.",
      "properties": {
        "review_id": { "type": "string" },
        "reviewer_id": { "type": "string" },
        "decision": {
          "type": "string",
          "enum": ["approved", "approved_with_changes", "rejected", "pending"]
        },
        "reviewed_at": { "type": "string", "format": "date-time" }
      }
    },
    "conflicts": {
      "type": "array",
      "description": "Inter-domain judgment conflicts detected during cluster composition.",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "value_conflict",
              "term_conflict",
              "risk_conflict",
              "stance_conflict",
              "framework_conflict"
            ]
          },
          "description": { "type": "string" },
          "involved_domains": { "type": "array", "items": { "type": "string" } },
          "resolution": {
            "type": "string",
            "enum": ["surfaced", "priority_wins", "risk_wins", "blocked", "asked_user"]
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Extensible metadata.",
      "properties": {
        "tags": { "type": "array", "items": { "type": "string" } },
        "environment": { "type": "string", "enum": ["dev", "staging", "production"] },
        "engine": { "type": "string", "description": "Engine that produced this trace." },
        "engine_version": { "type": "string" },
        "pipeline_run_id": { "type": "string", "description": "RFC-0012 Run ID." },
        "stage_id": { "type": "string", "description": "RFC-0012 Stage ID within the pipeline." }
      }
    }
  }
}
