{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aikdna/kdna/specs/runtime-capsule-1.schema.json",
  "title": "KDNA Runtime Capsule 1",
  "description": "Frozen compatibility schema. The historical asset_digest member means E (kdna-runtime-entry-set-v1), never the final container digest A.",
  "type": "object",
  "required": [
    "type",
    "version",
    "domain",
    "judgment_version",
    "asset_digest",
    "signature",
    "access",
    "risk_level",
    "profile",
    "context",
    "trace"
  ],
  "additionalProperties": true,
  "properties": {
    "type": { "const": "kdna.context.capsule" },
    "version": { "const": "1.0" },
    "domain": { "type": ["string", "null"] },
    "judgment_version": { "type": ["string", "null"] },
    "asset_digest": {
      "description": "Frozen Capsule 1 name for the runtime entry-set digest E.",
      "oneOf": [{ "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }, { "type": "null" }]
    },
    "signature": { "$ref": "#/$defs/signature" },
    "access": { "type": "string" },
    "risk_level": { "type": ["string", "null"] },
    "profile": { "enum": ["index", "compact", "scenario", "full"] },
    "context": { "type": "object" },
    "trace": { "$ref": "#/$defs/trace" }
  },
  "$defs": {
    "signature": {
      "type": "object",
      "required": ["state"],
      "additionalProperties": false,
      "properties": {
        "state": { "enum": ["verified", "not_checked", "absent"] },
        "issuer": { "type": "string", "minLength": 1 }
      }
    },
    "trace": {
      "type": "object",
      "required": [
        "payload_encoding",
        "loaded_by",
        "loaded_at",
        "schema_valid",
        "signature_state",
        "profile"
      ],
      "additionalProperties": true,
      "properties": {
        "payload_encoding": { "const": "cbor" },
        "loaded_by": { "const": "kdna-core" },
        "loaded_at": { "type": "string", "format": "date-time" },
        "schema_valid": { "type": "boolean" },
        "signature_state": { "enum": ["verified", "not_checked", "absent"] },
        "profile": { "enum": ["index", "compact", "scenario", "full"] }
      }
    }
  }
}
