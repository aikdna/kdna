{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aikdna/kdna/specs/agent-host-2-receipt.schema.json",
  "title": "KDNA Agent Host 2 Correlated Response Receipt",
  "description": "Host 2 response envelope. runtime_receipt proves only that the correlated Host boundary accepted the exact Capsule 2 value; it does not prove semantic consumption or conformance.",
  "type": "object",
  "required": ["protocol", "request_id", "runtime_receipt", "outcome"],
  "additionalProperties": false,
  "properties": {
    "protocol": { "const": "kdna.agent-host/2" },
    "request_id": { "type": "string", "pattern": "^host_[0-9a-f]{24}$" },
    "runtime_receipt": { "$ref": "#/$defs/runtimeReceipt" },
    "outcome": {
      "oneOf": [{ "$ref": "#/$defs/outcome" }, { "type": "null" }]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "runtime_receipt": {
            "properties": { "provider_execution_status": { "const": "completed" } },
            "required": ["provider_execution_status"]
          }
        },
        "required": ["runtime_receipt"]
      },
      "then": { "properties": { "outcome": { "$ref": "#/$defs/outcome" } } },
      "else": { "properties": { "outcome": { "type": "null" } } }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "runtimeReceipt": {
      "type": "object",
      "required": [
        "type",
        "receipt_version",
        "capsule_version",
        "capsule_digest_profile",
        "sender_capsule_delivery_digest",
        "host_recomputed_capsule_delivery_digest",
        "echoed_capsule_delivery_digest",
        "capsule_delivery_comparison",
        "capsule_schema_validation",
        "asset_id_correlation",
        "provider_execution_status",
        "semantic_consumption",
        "model_identity"
      ],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "kdna.agent-host.runtime-receipt" },
        "receipt_version": { "const": "1.0.0" },
        "capsule_version": { "const": "2.0" },
        "capsule_digest_profile": { "const": "kdna-capsule-jcs-v1" },
        "sender_capsule_delivery_digest": { "$ref": "#/$defs/sha256" },
        "host_recomputed_capsule_delivery_digest": { "$ref": "#/$defs/sha256" },
        "echoed_capsule_delivery_digest": { "$ref": "#/$defs/sha256" },
        "capsule_delivery_comparison": { "const": "matched" },
        "capsule_schema_validation": { "const": "passed" },
        "asset_id_correlation": { "const": "matched" },
        "provider_execution_status": {
          "enum": ["completed", "failed", "cancelled", "timed_out", "not_started"]
        },
        "semantic_consumption": { "$ref": "#/$defs/semanticConsumption" },
        "model_identity": { "$ref": "#/$defs/modelIdentity" }
      }
    },
    "semanticConsumption": {
      "type": "object",
      "required": ["state", "basis"],
      "additionalProperties": false,
      "properties": {
        "state": { "const": "not_observed" },
        "basis": { "type": "null" }
      }
    },
    "modelIdentity": {
      "type": "object",
      "required": ["value", "basis"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": ["string", "null"], "minLength": 1 },
        "basis": { "enum": ["host_reported", "not_observed"] }
      },
      "allOf": [
        {
          "if": {
            "properties": { "basis": { "const": "host_reported" } },
            "required": ["basis"]
          },
          "then": { "properties": { "value": { "type": "string", "minLength": 1 } } },
          "else": { "properties": { "value": { "type": "null" } } }
        }
      ]
    },
    "outcome": {
      "type": "object",
      "required": ["judgment", "usage"],
      "additionalProperties": false,
      "properties": {
        "judgment": { "$ref": "#/$defs/judgment" },
        "usage": {
          "oneOf": [{ "$ref": "#/$defs/usage" }, { "type": "null" }]
        }
      }
    },
    "judgment": {
      "type": "object",
      "required": ["answer", "reasoning", "confidence"],
      "additionalProperties": false,
      "properties": {
        "answer": { "type": "string", "minLength": 1 },
        "reasoning": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "usage": {
      "type": "object",
      "required": ["tokens_used", "model_calls"],
      "additionalProperties": false,
      "properties": {
        "tokens_used": { "type": "integer", "minimum": 0 },
        "model_calls": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
