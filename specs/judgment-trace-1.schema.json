{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aikdna/kdna/specs/judgment-trace-1.schema.json",
  "title": "KDNA JudgmentTrace 1.0",
  "description": "Authoritative strict execution-evidence contract for ConsumptionPlan 1.0. This is distinct from the historical CLI Consumption Trace v1 and JudgmentTrace 0.9 candidate.",
  "type": "object",
  "required": [
    "type",
    "trace_version",
    "trace_id",
    "plan_id",
    "parent_trace_id",
    "timestamp",
    "overall_status",
    "plan_integrity",
    "runtime_contract",
    "asset_identity",
    "digest_evidence",
    "capsule_delivery_evidence",
    "projection_actual",
    "host_receipt",
    "execution",
    "result_ref",
    "errors",
    "warnings"
  ],
  "additionalProperties": false,
  "properties": {
    "type": { "const": "kdna.judgment.trace" },
    "trace_version": { "const": "1.0.0" },
    "trace_id": { "type": "string", "pattern": "^trace_[0-9a-f]{16}$" },
    "plan_id": { "type": "string", "pattern": "^plan_[0-9a-f]{16}$" },
    "parent_trace_id": {
      "oneOf": [{ "type": "string", "pattern": "^trace_[0-9a-f]{16}$" }, { "type": "null" }]
    },
    "timestamp": { "type": "string", "format": "date-time" },
    "overall_status": {
      "enum": ["execution_completed", "blocked", "execution_failed", "cancelled", "timed_out"]
    },
    "plan_integrity": { "$ref": "#/$defs/planIntegrity" },
    "runtime_contract": { "$ref": "#/$defs/runtimeContract" },
    "asset_identity": { "$ref": "#/$defs/assetIdentity" },
    "digest_evidence": {
      "$ref": "https://github.com/aikdna/kdna/specs/digest-evidence.schema.json"
    },
    "capsule_delivery_evidence": { "$ref": "#/$defs/capsuleDeliveryEvidence" },
    "projection_actual": { "$ref": "#/$defs/projectionActual" },
    "host_receipt": {
      "oneOf": [
        {
          "$ref": "https://github.com/aikdna/kdna/specs/agent-host-2-receipt.schema.json"
        },
        { "type": "null" }
      ]
    },
    "execution": { "$ref": "#/$defs/execution" },
    "result_ref": {
      "oneOf": [{ "$ref": "#/$defs/resultRef" }, { "type": "null" }]
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "overall_status": { "const": "execution_completed" } },
        "required": ["overall_status"]
      },
      "then": {
        "properties": {
          "plan_integrity": {
            "properties": { "comparison": { "const": "matched" } }
          },
          "runtime_contract": {
            "properties": { "negotiation_state": { "const": "selected" } }
          },
          "digest_evidence": {
            "properties": {
              "asset": { "$ref": "#/$defs/successfulDigest" },
              "content": { "$ref": "#/$defs/successfulDigest" },
              "runtime_entry_set": { "$ref": "#/$defs/successfulDigest" }
            }
          },
          "execution": {
            "properties": {
              "delivery_status": { "const": "correlated_response" },
              "execution_status": { "const": "completed" }
            }
          },
          "result_ref": { "$ref": "#/$defs/resultRef" }
        }
      }
    },
    {
      "if": {
        "properties": {
          "runtime_contract": {
            "properties": { "selected_host_protocol": { "const": "kdna.agent-host/2" } },
            "required": ["selected_host_protocol"]
          },
          "overall_status": { "const": "execution_completed" }
        },
        "required": ["runtime_contract", "overall_status"]
      },
      "then": {
        "properties": {
          "host_receipt": {
            "$ref": "https://github.com/aikdna/kdna/specs/agent-host-2-receipt.schema.json"
          },
          "capsule_delivery_evidence": {
            "properties": { "host_boundary_comparison": { "const": "matched" } }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "execution": {
            "properties": { "delivery_status": { "const": "not_delivered" } },
            "required": ["delivery_status"]
          }
        },
        "required": ["execution"]
      },
      "then": { "properties": { "host_receipt": { "type": "null" } } }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "assetId": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9_-]*(:[a-zA-Z0-9_.-]+)+$"
    },
    "semver": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+([+-].+)?$"
    },
    "planIntegrity": {
      "type": "object",
      "required": ["profile", "plan_digest", "comparison"],
      "additionalProperties": false,
      "properties": {
        "profile": { "const": "kdna-consumption-plan-jcs-v1" },
        "plan_digest": {
          "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
        },
        "comparison": { "enum": ["matched", "mismatched", "unavailable"] }
      },
      "allOf": [
        {
          "if": {
            "properties": { "comparison": { "const": "unavailable" } },
            "required": ["comparison"]
          },
          "then": { "properties": { "plan_digest": { "type": "null" } } },
          "else": { "properties": { "plan_digest": { "$ref": "#/$defs/sha256" } } }
        }
      ]
    },
    "runtimeContract": {
      "type": "object",
      "required": [
        "plan_capsule_versions",
        "core_capsule_versions",
        "host_capsule_versions",
        "plan_host_protocols",
        "host_protocols",
        "capability_basis",
        "negotiation_state",
        "source_capsule_version",
        "selected_capsule_version",
        "selected_host_protocol",
        "adapter",
        "issue_code"
      ],
      "additionalProperties": false,
      "properties": {
        "plan_capsule_versions": { "$ref": "#/$defs/capsuleVersions" },
        "core_capsule_versions": { "$ref": "#/$defs/capsuleVersions" },
        "host_capsule_versions": { "$ref": "#/$defs/observedCapsuleVersions" },
        "plan_host_protocols": { "$ref": "#/$defs/hostProtocols" },
        "host_protocols": { "$ref": "#/$defs/observedHostProtocols" },
        "capability_basis": {
          "enum": ["registered_descriptor", "legacy_assumption", "not_observed"]
        },
        "negotiation_state": { "enum": ["selected", "blocked", "not_started"] },
        "source_capsule_version": {
          "type": ["string", "null"],
          "enum": ["2.0", "1.0", null]
        },
        "selected_capsule_version": {
          "type": ["string", "null"],
          "enum": ["2.0", "1.0", null]
        },
        "selected_host_protocol": {
          "type": ["string", "null"],
          "enum": ["kdna.agent-host/2", "kdna.agent-host/1", null]
        },
        "adapter": {
          "type": ["string", "null"],
          "enum": ["kdna-capsule-2-to-1/v1", null]
        },
        "issue_code": {
          "type": ["string", "null"],
          "enum": [
            "KDNA_CAPSULE_VERSION_UNSUPPORTED",
            "KDNA_HOST_PROTOCOL_UNSUPPORTED",
            "KDNA_HOST_CAPSULE_PAIR_UNSUPPORTED",
            null
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "negotiation_state": { "const": "selected" } },
            "required": ["negotiation_state"]
          },
          "then": {
            "properties": {
              "selected_capsule_version": { "type": "string" },
              "selected_host_protocol": { "type": "string" },
              "issue_code": { "type": "null" }
            }
          },
          "else": {
            "if": {
              "properties": { "negotiation_state": { "const": "blocked" } },
              "required": ["negotiation_state"]
            },
            "then": {
              "properties": {
                "source_capsule_version": { "type": "null" },
                "selected_capsule_version": { "type": "null" },
                "selected_host_protocol": { "type": "null" },
                "adapter": { "type": "null" },
                "issue_code": { "type": "string" }
              }
            },
            "else": {
              "properties": {
                "source_capsule_version": { "type": "null" },
                "selected_capsule_version": { "type": "null" },
                "selected_host_protocol": { "type": "null" },
                "adapter": { "type": "null" },
                "issue_code": { "type": "null" }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "selected_host_protocol": { "const": "kdna.agent-host/2" } },
            "required": ["selected_host_protocol"]
          },
          "then": {
            "properties": {
              "selected_capsule_version": { "const": "2.0" },
              "adapter": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": { "selected_host_protocol": { "const": "kdna.agent-host/1" } },
            "required": ["selected_host_protocol"]
          },
          "then": {
            "properties": { "selected_capsule_version": { "const": "1.0" } }
          }
        },
        {
          "if": {
            "properties": { "capability_basis": { "const": "not_observed" } },
            "required": ["capability_basis"]
          },
          "then": {
            "properties": {
              "host_capsule_versions": { "maxItems": 0 },
              "host_protocols": { "maxItems": 0 },
              "negotiation_state": { "const": "not_started" }
            }
          }
        }
      ]
    },
    "capsuleVersions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["2.0", "1.0"] }
    },
    "hostProtocols": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "enum": ["kdna.agent-host/2", "kdna.agent-host/1"] }
    },
    "observedCapsuleVersions": {
      "type": "array",
      "uniqueItems": true,
      "items": { "enum": ["2.0", "1.0"] }
    },
    "observedHostProtocols": {
      "type": "array",
      "uniqueItems": true,
      "items": { "enum": ["kdna.agent-host/2", "kdna.agent-host/1"] }
    },
    "assetIdentity": {
      "type": "object",
      "required": ["asset_id", "asset_uid", "version"],
      "additionalProperties": false,
      "properties": {
        "asset_id": { "$ref": "#/$defs/assetId" },
        "asset_uid": {
          "oneOf": [{ "type": "string", "format": "uri" }, { "type": "null" }]
        },
        "version": { "$ref": "#/$defs/semver" }
      }
    },
    "successfulDigest": {
      "type": "object",
      "required": ["value", "basis", "comparison"],
      "additionalProperties": false,
      "properties": {
        "value": { "$ref": "#/$defs/sha256" },
        "basis": { "type": "string" },
        "comparison": {
          "type": "object",
          "required": ["state", "against", "expected", "source"],
          "additionalProperties": false,
          "properties": {
            "state": { "enum": ["matched", "not_compared"] },
            "against": { "type": ["string", "null"] },
            "expected": {
              "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
            },
            "source": { "type": ["string", "null"] }
          }
        }
      }
    },
    "capsuleDeliveryEvidence": {
      "type": "object",
      "required": [
        "basis",
        "observed",
        "sender_computed",
        "host_recomputed",
        "host_echoed",
        "delivered_capsule_version",
        "host_boundary_comparison",
        "request_id"
      ],
      "additionalProperties": false,
      "properties": {
        "basis": { "const": "kdna-capsule-jcs-v1" },
        "observed": {
          "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
        },
        "sender_computed": { "type": "boolean" },
        "host_recomputed": {
          "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
        },
        "host_echoed": {
          "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
        },
        "delivered_capsule_version": {
          "type": ["string", "null"],
          "enum": ["2.0", "1.0", null]
        },
        "host_boundary_comparison": {
          "enum": ["matched", "mismatched", "not_delivered", "not_observed", "unavailable"]
        },
        "request_id": {
          "oneOf": [{ "type": "string", "pattern": "^host_[0-9a-f]{24}$" }, { "type": "null" }]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "sender_computed": { "const": true } },
            "required": ["sender_computed"]
          },
          "then": { "properties": { "observed": { "$ref": "#/$defs/sha256" } } },
          "else": { "properties": { "observed": { "type": "null" } } }
        },
        {
          "if": {
            "properties": {
              "host_boundary_comparison": { "enum": ["matched", "mismatched"] }
            },
            "required": ["host_boundary_comparison"]
          },
          "then": {
            "properties": {
              "observed": { "$ref": "#/$defs/sha256" },
              "sender_computed": { "const": true },
              "host_recomputed": { "$ref": "#/$defs/sha256" },
              "host_echoed": { "$ref": "#/$defs/sha256" },
              "delivered_capsule_version": { "type": "string" },
              "request_id": { "type": "string", "pattern": "^host_[0-9a-f]{24}$" }
            }
          }
        },
        {
          "if": {
            "properties": { "host_boundary_comparison": { "const": "not_delivered" } },
            "required": ["host_boundary_comparison"]
          },
          "then": {
            "properties": {
              "host_recomputed": { "type": "null" },
              "host_echoed": { "type": "null" },
              "delivered_capsule_version": { "type": "null" },
              "request_id": { "type": "null" }
            }
          }
        },
        {
          "if": {
            "properties": { "host_boundary_comparison": { "const": "unavailable" } },
            "required": ["host_boundary_comparison"]
          },
          "then": {
            "properties": {
              "observed": { "type": "null" },
              "sender_computed": { "const": false },
              "host_recomputed": { "type": "null" },
              "host_echoed": { "type": "null" },
              "delivered_capsule_version": { "type": "null" },
              "request_id": { "type": "null" }
            }
          }
        }
      ]
    },
    "projectionActual": {
      "type": "object",
      "required": ["profile", "capsule_delivery_digest", "profile_deviated_from_plan"],
      "additionalProperties": false,
      "properties": {
        "profile": {
          "type": ["string", "null"],
          "enum": ["index", "compact", "scenario", "full", null]
        },
        "capsule_delivery_digest": {
          "oneOf": [{ "$ref": "#/$defs/sha256" }, { "type": "null" }]
        },
        "profile_deviated_from_plan": { "type": ["boolean", "null"] }
      }
    },
    "execution": {
      "type": "object",
      "required": [
        "delivery_status",
        "semantic_consumption",
        "execution_status",
        "conformance_status",
        "model_identity"
      ],
      "additionalProperties": false,
      "properties": {
        "delivery_status": {
          "enum": ["correlated_response", "delivered_unconfirmed", "not_delivered"]
        },
        "semantic_consumption": { "$ref": "#/$defs/semanticConsumption" },
        "execution_status": {
          "enum": ["completed", "not_started", "failed", "cancelled", "timed_out"]
        },
        "conformance_status": { "const": "not_evaluated" },
        "model_identity": { "$ref": "#/$defs/modelIdentity" }
      }
    },
    "semanticConsumption": {
      "type": "object",
      "required": ["state", "basis"],
      "additionalProperties": false,
      "properties": {
        "state": { "const": "not_observed" },
        "basis": { "type": "null" }
      }
    },
    "modelIdentity": {
      "type": "object",
      "required": ["value", "basis"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": ["string", "null"], "minLength": 1 },
        "basis": { "enum": ["host_reported", "not_observed"] }
      },
      "allOf": [
        {
          "if": {
            "properties": { "basis": { "const": "host_reported" } },
            "required": ["basis"]
          },
          "then": { "properties": { "value": { "type": "string", "minLength": 1 } } },
          "else": { "properties": { "value": { "type": "null" } } }
        }
      ]
    },
    "resultRef": {
      "type": "object",
      "required": ["result_digest", "basis", "stored"],
      "additionalProperties": false,
      "properties": {
        "result_digest": { "$ref": "#/$defs/sha256" },
        "basis": { "const": "kdna-result-jcs-v1" },
        "stored": { "type": "boolean" }
      }
    },
    "issue": {
      "type": "object",
      "required": ["code", "message", "phase"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "phase": {
          "enum": ["plan", "negotiation", "load", "delivery", "host", "execution"]
        }
      }
    }
  }
}
